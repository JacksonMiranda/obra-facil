# ─────────────────────────────────────────────────────────────
# Obra Fácil — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Banco de Dados ───────────────────────────────────────────
# Local (Docker): postgresql://obrafacil:obrafacil@localhost:5433/obrafacil_db
# Produção (Supabase): postgresql://postgres.[ref]:[password]@pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://obrafacil:obrafacil@localhost:5433/obrafacil_db

# ── Clerk ────────────────────────────────────────────────────
# Encontrado em: https://dashboard.clerk.com/apps/<seu-app>/api-keys
# ATENÇÃO: DISABLE_CLERK_AUTH=true desliga a autenticação e permite
# qualquer cliente acessar a API via header X-Dev-User-Id. Use SOMENTE
# em dev local. Em NODE_ENV=production o backend aborta se isso estiver true.
DISABLE_CLERK_AUTH=false
CLERK_SECRET_KEY=sk_test_<...>
CLERK_WEBHOOK_SECRET=whsec_<...>

# ── Servidor ─────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ── IA (Google Gemini) ────────────────────────────────────────
# Gere uma chave gratuita em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=REMOVED_EXPOSED_KEY
