# ─────────────────────────────────────────────────────────────
# Obra Fácil — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── NestJS API ───────────────────────────────────────────────
# Base URL of the api-obrafacil NestJS backend (no trailing slash)
# Local dev: http://localhost:3001/api
# Production: https://api.obrafacil.com/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ── Supabase ─────────────────────────────────────────────────
# Found at: https://app.supabase.com/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
# Service role key (server-only, never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── Clerk ────────────────────────────────────────────────────
# Found at: https://dashboard.clerk.com/apps/<your-app>/api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_<...>
CLERK_SECRET_KEY=sk_test_<...>

# Clerk webhook secret — set after creating a webhook in the Clerk dashboard
# pointing to: https://<your-vercel-url>/api/webhooks/clerk
CLERK_WEBHOOK_SECRET=whsec_<...>

# ── Clerk redirect URLs (optional, defaults are fine for local dev) ──
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
