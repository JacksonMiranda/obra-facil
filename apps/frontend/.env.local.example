# ─────────────────────────────────────────────────────────────────────────────
# Obra Fácil — Frontend Environment Variables
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA comite .env.local no controle de versão.
# ─────────────────────────────────────────────────────────────────────────────

# ── API NestJS ────────────────────────────────────────────────────────────────
# URL base do backend NestJS (sem barra final)
# Local dev: http://localhost:3001/api
# Produção: variável configurada no dashboard do Vercel
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ── Dev bypass (Clerk) ────────────────────────────────────────────────────────
# Em desenvolvimento local: defina como "true" para desabilitar Clerk
# Em produção: não defina esta variável (ou defina como "false")
NEXT_PUBLIC_DISABLE_CLERK_AUTH=true

# ── Clerk ─────────────────────────────────────────────────────────────────────
# Encontrado em: https://dashboard.clerk.com/apps/<seu-app>/api-keys
# (Necessário somente se NEXT_PUBLIC_DISABLE_CLERK_AUTH != true)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_<...>
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
