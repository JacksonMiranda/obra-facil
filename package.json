{
  "name": "obrafacil",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run start:dev --workspace=backend",
    "build": "npm run build --workspace=@obrafacil/shared && npm run build --workspace=backend && npm run build --workspace=frontend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:frontend": "npm run lint --workspace=frontend",
    "lint:backend": "npm run lint --workspace=backend",
    "test": "npm test --workspace=backend",
    "vercel-build": "npm run build --workspace=@obrafacil/shared && npm run build --workspace=frontend"
  },
  "overrides": {
    "@nestjs/core": {
      "path-to-regexp": "8.4.2"
    },
    "@nestjs/platform-express": {
      "path-to-regexp": "8.4.2"
    },
    "@nestjs/swagger": {
      "path-to-regexp": "8.4.2"
    },
    "picomatch": "4.0.4"
  },
  "devDependencies": {
    "wait-on": "^9.0.5"
  }
}
