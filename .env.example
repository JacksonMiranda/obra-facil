# ───────────────────────────────────────────────────────────────
# Obra Fácil — Raiz do Monorepo (variáveis de orquestração)
# Variáveis das aplicações ficam em:
#   apps/backend/.env
#   apps/frontend/.env.local
# ───────────────────────────────────────────────────────────────

# GitHub (necessário apenas para scripts de automazione)
# https://github.com/settings/tokens/new
GITHUB_PERSONAL_ACCESS_TOKEN=

# Vercel (necessário apenas para scripts de deploy)
# https://vercel.com/account/settings/tokens
VERCEL_API_TOKEN=
CONTEXT7_API_KEY=

#Backend para Frontend
NEXT_PUBLIC_API_URL=

#Portas
FRONTEND_PORT=
BACKEND_PORT=
